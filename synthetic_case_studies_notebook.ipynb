   "source": [
    "## 3. Subgroup Heterogeneity\n",
    "\n",
    "Overall mean difference near zero, but distinct subgroups shift in different directions.\n",
    "\n",
    "### 3.0 Ground Truth: Slopegraph colored by true subgroup membership\n",
    "\n",
    "These slopegraphs show the same data as the subsequent plots, but with lines\n",
    "colored by their **true** subgroup membership (known from the data-generating process).\n",
    "This serves as a reference for evaluating whether EZ-Pair Graph's clustering\n",
    "correctly recovers the hidden structure.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "90cb4251",
   "metadata": {},
   "outputs": [],
   "source": [
    "subgroup_keys = [k for k in DATA if k.startswith(\"Equal\") or k.startswith(\"Unequal\") or k.startswith(\"3 groups\")]\n",
    "n_sub = len(subgroup_keys)\n",
    "\n",
    "# Color palette for subgroups\n",
    "palette = {\n",
    "    \"High baseline, descending\": \"#d62728\",\n",
    "    \"Low baseline, ascending\": \"#2ca02c\",\n",
    "    \"Majority, small decrease\": \"#d62728\",\n",
    "    \"Minority, large increase\": \"#2ca02c\",\n",
    "    \"Urban, increase\": \"#2ca02c\",\n",
    "    \"Suburban, stable\": \"#7f7f7f\",\n",
    "    \"Rural, decrease\": \"#d62728\",\n",
    "}\n",
    "\n",
    "fig, axes = plt.subplots(1, n_sub, figsize=(5*n_sub, 5))\n",
    "for idx, key in enumerate(subgroup_keys):\n",
    "    a, b = DATA[key]\n",
    "    labels = LABELS[key]\n",
    "    ax = axes[idx]\n",
    "\n",
    "    unique_labels = list(dict.fromkeys(labels))  # preserve order\n",
    "    for lbl in unique_labels:\n",
    "        mask = labels == lbl\n",
    "        color = palette.get(lbl, \"#1f77b4\")\n",
    "        n_lbl = mask.sum()\n",
    "        for ai, bi in zip(a[mask], b[mask]):\n",
    "            ax.plot([0, 1], [ai, bi], color=color, alpha=0.15, linewidth=0.5)\n",
    "        # One dummy line for legend\n",
    "        ax.plot([], [], color=color, linewidth=2, label=f\"{lbl} (n={n_lbl})\")\n",
    "\n",
    "    ax.set_xlim(-0.2, 1.2)\n",
    "    ax.set_xticks([0, 1])\n",
    "    ax.set_xticklabels([\"Group A\", \"Group B\"])\n",
    "    ax.set_ylabel(\"Value\")\n",
    "    ax.set_title(key, fontsize=11, fontweight=\"bold\")\n",
    "    ax.legend(fontsize=7, loc=\"upper left\")\n",
    "    if idx > 0: ax.set_ylabel(\"\")\n",
    "\n",
    "fig.suptitle(\"Ground Truth Slopegraph (colored by true subgroup)\", fontsize=15, fontweight=\"bold\", y=1.02)\n",
    "fig.tight_layout()\n",
    "fig.savefig(f\"{OUTPUT_BASE}/subgroup_ground_truth.png\", dpi=200, bbox_inches=\"tight\")\n",
    "plt.show()\n"
   ]
  },
