   "source": [
    "csv_dir = f\"{OUTPUT_BASE}/csv\"\n",
    "os.makedirs(csv_dir, exist_ok=True)\n",
    "for key, (a, b) in DATA.items():\n",
    "    fname = key.replace(\" \",\"_\").replace(\",\",\"\").replace(\"=\",\"\").replace(\"%\",\"pct\").replace(\":\",\"\").replace(\"/\",\"_\").replace(\"±\",\"pm\").replace(\"(\",\"\").replace(\")\",\"\") + \".csv\"\n",
    "    np.savetxt(os.path.join(csv_dir, fname), np.column_stack([a,b]),\n",
    "               delimiter=\",\", header=\"group_A,group_B\", comments=\"\", fmt=\"%.6f\")\n",
    "print(f\"Saved {len(DATA)} CSV files to {csv_dir}/\")\n"
