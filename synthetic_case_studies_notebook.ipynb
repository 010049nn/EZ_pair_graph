   "source": [
　　"[![Open In Colab](https://colab.research.google.com/assets/colab-badge.svg)](https://colab.research.google.com/github/010049nn/EZ_pair_graph/blob/main/synthetic_case_studies_notebook.ipynb)",
    "# EZ-Pair Graph: Synthetic Data Case Studies\n",
    "\n",
    "Comprehensive evaluation of all three EZ-Pair Graph plot types (trapezoid, clustered line, parallel arrow) across controlled data-generating conditions.\n",
    "\n",
    "**Reproducibility:** All data generated with fixed seeds (`MASTER_SEED = 20260331`).\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a95da9d1",
   "metadata": {},
   "source": [
    "## 0. Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ea81113e",
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install git+https://github.com/010049nn/EZ_pair_graph.git -q\n\nimport ez_pair_graph as ezpg\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport os\nimport hashlib\n\nprint(f\"ez-pair-graph version: {ezpg.__version__}\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "15d3d7a6",
   "metadata": {},
   "source": [
    "## 1. Data Generation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "09a6d86b",
   "metadata": {},
   "outputs": [],
   "source": [
    "MASTER_SEED = 20260331\nN = 2000\nMU_A = 100.0\nSIGMA = 15.0\nOUTPUT_BASE = \"output_synthetic\"\nos.makedirs(OUTPUT_BASE, exist_ok=True)\n\ndef make_seed(master, scenario_id):\n    s = f\"{master}_{scenario_id}\".encode()\n    return int(hashlib.sha256(s).hexdigest(), 16) % (2**31)\n\ndef gen_bvn(n, mu_a, mu_b, sigma, rho, rng):\n    cov = rho * sigma * sigma\n    data = rng.multivariate_normal([mu_a, mu_b], [[sigma**2, cov],[cov, sigma**2]], size=n)\n    return data[:, 0], data[:, 1]\n\ndef gen_bvn_hetero(n, mu_a, mu_b, sigma_a, sigma_b, rho, rng):\n    cov = rho * sigma_a * sigma_b\n    data = rng.multivariate_normal([mu_a, mu_b], [[sigma_a**2, cov],[cov, sigma_b**2]], size=n)\n    return data[:, 0], data[:, 1]\n\ndef plot_row(keys, data, plot_func, titles=None, suptitle=\"\", fname=\"\", extra_kw=None):\n    \"\"\"Helper: plot a horizontal row of panels with a given plot function.\"\"\"\n    n_panels = len(keys)\n    fig, axes = plt.subplots(1, n_panels, figsize=(5*n_panels, 5))\n    if n_panels == 1: axes = [axes]\n    for idx, key in enumerate(keys):\n        a, b = data[key]\n        ax = axes[idx]\n        kw = extra_kw or {}\n        if plot_func in (ezpg.plot_clustered_lines, ezpg.plot_parallel_arrows):\n            result = ezpg.cluster_data(a, b)\n            stats = ezpg.compute_statistics(result['x'], result['y'], result['clusters'])\n            plot_func(result['x'], result['y'], clusters=result['clusters'], stats=stats,\n                      ax=ax, show_numbers=True, **kw)\n        else:\n            plot_func(a, b, ax=ax, **kw)\n        t = titles[idx] if titles else key\n        ax.set_title(t, fontsize=11, fontweight=\"bold\")\n        if idx > 0: ax.set_ylabel(\"\")\n    fig.suptitle(suptitle, fontsize=14, fontweight=\"bold\", y=1.02)\n    fig.tight_layout()\n    if fname:\n        fig.savefig(f\"{OUTPUT_BASE}/{fname}\", dpi=200, bbox_inches=\"tight\")\n    plt.show()\n\nDATA = {}\n\n# 1. Grid\nCORRELATIONS = [0.3, 0.6, 0.9]\nEFFECT_SIZES = [0.0, 0.2, 0.5, 0.8]\nfor rho in CORRELATIONS:\n    for d in EFFECT_SIZES:\n        rng = np.random.default_rng(make_seed(MASTER_SEED, f\"grid_rho{rho}_d{d}\"))\n        a, b = gen_bvn(N, MU_A, MU_A + d*SIGMA, SIGMA, rho, rng)\n        DATA[f\"r={rho}, d={d}\"] = (a, b)\n\n# 2. RTM\nRTM_RHOS = [0.3, 0.5, 0.7, 0.9, 0.95]\nfor rho in RTM_RHOS:\n    rng = np.random.default_rng(make_seed(MASTER_SEED, f\"rtm_rho{rho}\"))\n    a, b = gen_bvn(N, MU_A, MU_A, SIGMA, rho, rng)\n    DATA[f\"RTM r={rho}\"] = (a, b)\n\n# 3. Subgroup (also store true labels)\nLABELS = {}\n\nfor rho in [0.6, 0.9]:\n    rng = np.random.default_rng(make_seed(MASTER_SEED, f\"subgroup_equal_rho{rho}\"))\n    n_h = N // 2\n    a1, b1 = gen_bvn(n_h, MU_A+10, MU_A+10-0.5*SIGMA, SIGMA, rho, rng)\n    a2, b2 = gen_bvn(n_h, MU_A-10, MU_A-10+0.5*SIGMA, SIGMA, rho, rng)\n    key = f\"Equal 50:50, d=pm0.5, r={rho}\"\n    DATA[key] = (np.concatenate([a1,a2]), np.concatenate([b1,b2]))\n    LABELS[key] = np.array([\"High baseline, descending\"]*n_h + [\"Low baseline, ascending\"]*n_h)\n\nfor rho in [0.6, 0.9]:\n    rng = np.random.default_rng(make_seed(MASTER_SEED, f\"subgroup_unequal_rho{rho}\"))\n    n_l, n_s = int(N*0.7), N - int(N*0.7)\n    a1, b1 = gen_bvn(n_l, MU_A, MU_A-0.2*SIGMA, SIGMA, rho, rng)\n    a2, b2 = gen_bvn(n_s, MU_A+20, MU_A+20+0.8*SIGMA, SIGMA, rho, rng)\n    key = f\"Unequal 70:30, d=-0.2/+0.8, r={rho}\"\n    DATA[key] = (np.concatenate([a1,a2]), np.concatenate([b1,b2]))\n    LABELS[key] = np.array([\"Majority, small decrease\"]*n_l + [\"Minority, large increase\"]*n_s)\n\nrng = np.random.default_rng(make_seed(MASTER_SEED, \"subgroup_three_rho0.8\"))\nn1, n2 = int(N*0.2), int(N*0.5); n3 = N - n1 - n2\na1, b1 = gen_bvn(n1, 130, 130+0.5*SIGMA, SIGMA*1.2, 0.8, rng)\na2, b2 = gen_bvn(n2, 100, 100, SIGMA, 0.8, rng)\na3, b3 = gen_bvn(n3, 85, 85-0.3*SIGMA, SIGMA*0.8, 0.8, rng)\nkey = \"3 groups (20:50:30), r=0.8\"\nDATA[key] = (np.concatenate([a1,a2,a3]), np.concatenate([b1,b2,b3]))\nLABELS[key] = np.array([\"Urban, increase\"]*n1 + [\"Suburban, stable\"]*n2 + [\"Rural, decrease\"]*n3)\n\n# 4. Skewed (log-normal)\nfor rho in [0.6, 0.9]:\n    for d in [0.0, 0.3]:\n        rng = np.random.default_rng(make_seed(MASTER_SEED, f\"lognormal_rho{rho}_d{d}\"))\n        za, zb = gen_bvn(N, 4.0, 4.0+d*0.5, 0.5, rho, rng)\n        DATA[f\"LogNorm r={rho}, d={d}\"] = (np.exp(za), np.exp(zb))\n\n# 5. Heteroscedasticity\nfor d in [0.0, 0.5]:\n    rng = np.random.default_rng(make_seed(MASTER_SEED, f\"hetero_2x_r06_d{d}\"))\n    a, b = gen_bvn_hetero(N, MU_A, MU_A+d*SIGMA, SIGMA, SIGMA*2, 0.6, rng)\n    DATA[f\"Hetero 2xSD, d={d}\"] = (a, b)\n\n# 6. Outliers\nfor d in [0.0, 0.5]:\n    rng = np.random.default_rng(make_seed(MASTER_SEED, f\"outlier_5pct_d{d}\"))\n    cov_n = 0.9 * SIGMA**2\n    data = rng.multivariate_normal([MU_A, MU_A+d*SIGMA], [[SIGMA**2, cov_n],[cov_n, SIGMA**2]], size=N)\n    a, b = data[:,0], data[:,1]\n    n_out = int(N*0.05)\n    idx = rng.choice(N, n_out, replace=False)\n    a[idx] += rng.normal(0, SIGMA*3, n_out)\n    b[idx] += rng.normal(0, SIGMA*3, n_out)\n    DATA[f\"5pct outliers, d={d}\"] = (a, b)\n\nprint(f\"Generated {len(DATA)} scenarios, n={N} each.\")\n"
   ]
  },
