   "id": "55012ffe",
   "metadata": {},
   "source": [
    "### Sanity check"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8eecaf19",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(f\"{'Scenario':<40s} {'r':>6s} {'mean_d':>8s} {'SD_A':>6s} {'SD_B':>6s} {'%asc':>6s} {'%desc':>6s}\")\n",
    "print(\"-\" * 85)\n",
    "for name, (a, b) in DATA.items():\n",
    "    diff = b - a\n",
    "    r = np.corrcoef(a, b)[0, 1]\n",
    "    print(f\"{name:<40s} {r:6.3f} {np.mean(diff):8.2f} {np.std(a):6.1f} {np.std(b):6.1f} {np.mean(diff>0)*100:5.1f}% {np.mean(diff<0)*100:5.1f}%\")\n"
   ]
  },
